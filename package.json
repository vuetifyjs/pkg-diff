{
  "name": "pkg-diff",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "license": "GPL-3.0-only",
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "dev": "vite",
    "build:wasm": "cargo build --release --manifest-path wasm/Cargo.toml --target wasm32-unknown-unknown && cp wasm/target/wasm32-unknown-unknown/release/pkgdiff.wasm public/diff.wasm",
    "build": "vue-tsc --build --force && vite build",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "dependencies": {
    "@fontsource-variable/recursive": "^5.2.8",
    "@pierre/diffs": "^1.2.7",
    "@pierre/trees": "1.0.0-beta.4",
    "@plausible-analytics/tracker": "^0.4.5",
    "@vuetify/v0": "latest",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^24.12.0",
    "@unocss/transformer-directives": "^66.6.6",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^9.39.4",
    "eslint-config-vuetify": "^4.3.4",
    "typescript": "~5.9.3",
    "unocss": "^66.6.6",
    "vite": "^8.0.0",
    "vue-tsc": "^3.2.5"
  }
}
